; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Block Craft"
run/main_scene="res://scenes/LoadingScreen.tscn"
config/features=PackedStringArray("4.6", "Mobile")
boot_splash/bg_color=Color(0.93, 0.91, 0.88, 1)
boot_splash/show_image=false
config/icon="res://icon.svg"

[autoload]

GameState="*uid://c32xsgv2sledh"
SoundManager="*res://scripts/SoundManager.gd"
AdManager="*res://scripts/AdManager.gd"
SceneTransition="*res://scripts/SceneTransition.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1560
window/stretch/mode="canvas_items"
window/stretch/aspect="keep_width"
window/handheld/orientation="portrait"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

renderer/rendering_method="mobile"
